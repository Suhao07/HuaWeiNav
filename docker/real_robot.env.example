# Copy selected values into ~/.huawei_nav_real.env on the robot.
# Do not commit real keys.

MAP_PROVIDER=Amap
AMAP_KEY=<your-amap-key>

LLM_PROVIDER=ark
ARK_API_KEY=<your-ark-api-key>
LLM_MODEL=doubao-seed-2-0-pro-260215
LLM_API_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# Optional overrides. The defaults point to the downloaded Orin assets.
# SYSNAV_DETECTOR_MODEL_TYPE=yoloe
# SYSNAV_DETECTOR_MODEL_PATH=/home/orin26/code/HuaWeiNav/real_robot/ros2_ws/src/semantic_mapping/semantic_mapping/external/yoloe-11s-seg.pt
# SYSNAV_SAM2_CHECKPOINT=/home/orin26/code/HuaWeiNav/real_robot/ros2_ws/src/semantic_mapping/semantic_mapping/external/sam2/checkpoints/sam2.1_hiera_base_plus.pt

# Debug-safe real robot bringup defaults. Keep these blocked until the lower
# controller bridge has been checked on the robot.
# BLOCK_LOWER_CONTROLLER=1
# ENABLE_LOWER_CONTROLLER=0
# LOWER_CONTROLLER_CMD=
# REQUIRE_NO_CMD_VEL_PUBLISHERS=1
